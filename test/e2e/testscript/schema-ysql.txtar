db yugabytedb/yugabyte:latest DB_URL
kubectl create secret generic db-creds --from-literal=url=${DB_URL}

# Wait for the first pod to be created
kubectl-wait-available deploy/yugabyte
# Wait for the DB ready before creating the schema
kubectl-wait-ready -l app=yugabyte pods

# Create the secret to store ATLAS_TOKEN
kubectl create secret generic atlas-token --from-literal=ATLAS_TOKEN=${ATLAS_TOKEN}

# Create the configmap to store the schema.sql
kubectl create configmap ysql-schema --from-file=./schema-v1 --dry-run=client -o yaml
stdin stdout
kubectl apply -f -

# Create the schema
kubectl apply -f schema.yaml
kubectl-wait-ready AtlasSchema/ysql

# Inspect the schema to ensure it's correct
atlas schema inspect -u "${DB_URL}"
cmp stdout schema-v1.hcl

# Make sure the dev database is automatically created
kubectl get deployment ysql-atlas-dev-db -o jsonpath='{.spec.template.spec.containers[0].image}'
stdout yugabytedb/yugabyte:latest

-- schema-v1.hcl --
table "users" {
  schema = schema.public
  column "id" {
    null = false
    type = bigint
  }
  column "name" {
    null = false
    type = character_varying
  }
  primary_key {
    columns = [column.id]
  }
}
schema "public" {
  comment = "standard public schema"
}
-- schema-v1/schema.sql --
create table users (
  id bigint not null,
  name varchar not null,
  primary key (id)
);
-- schema.yaml --
apiVersion: db.atlasgo.io/v1alpha1
kind: AtlasSchema
metadata:
  name: ysql
spec:
  urlFrom:
    secretKeyRef:
      name: db-creds
      key: url
  cloud:
    tokenFrom:
      secretKeyRef:
        name: atlas-token
        key: ATLAS_TOKEN
  schema:
    configMapKeyRef:
      key: schema.sql
      name: ysql-schema
